{
  "info": {
    "name": "TeamTask API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    },
    {
      "key": "auth_port",
      "value": "3000"
    },
    {
      "key": "project_port",
      "value": "3001"
    },
    {
      "key": "task_port",
      "value": "3002"
    },
    {
      "key": "history_port",
      "value": "3003"
    },
    {
      "key": "token_manager",
      "value": ""
    },
    {
      "key": "token_member",
      "value": ""
    },
    {
      "key": "manager_id",
      "value": ""
    },
    {
      "key": "member_id",
      "value": ""
    },
    {
      "key": "project_id",
      "value": ""
    },
    {
      "key": "task_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Register Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('token_manager', pm.response.json().token);",
                  "    pm.collectionVariables.set('manager_id', pm.response.json().user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{auth_port}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{auth_port}}",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Alice Manager\",\"email\":\"alice@teamtask.com\",\"password\":\"password123\",\"role\":\"manager\"}"
            }
          }
        },
        {
          "name": "1.2 Register Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('token_member', pm.response.json().token);",
                  "    pm.collectionVariables.set('member_id', pm.response.json().user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{auth_port}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{auth_port}}",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Bob Member\",\"email\":\"bob@teamtask.com\",\"password\":\"password123\",\"role\":\"member\"}"
            }
          }
        },
        {
          "name": "1.3 Login Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{auth_port}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{auth_port}}",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"alice@teamtask.com\",\"password\":\"password123\"}"
            }
          }
        },
        {
          "name": "1.4 Login Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{auth_port}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{auth_port}}",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"bob@teamtask.com\",\"password\":\"password123\"}"
            }
          }
        },
        {
          "name": "1.5 Get Current User (Manager)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{auth_port}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{auth_port}}",
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Projects",
      "item": [
        {
          "name": "2.1 Create Project (Manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('project_id', pm.response.json().project._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{project_port}}/api/projects",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{project_port}}",
              "path": [
                "api",
                "projects"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Refonte Web\",\"description\":\"Refactorisation\",\"deadline\":\"2026-12-31T23:59:59Z\",\"members\":[\"{{member_id}}\"]}"
            }
          }
        },
        {
          "name": "2.2 Get All Projects (Member/Manager)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_member}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{project_port}}/api/projects",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{project_port}}",
              "path": [
                "api",
                "projects"
              ]
            }
          }
        },
        {
          "name": "2.3 Get Project by ID (Member/Manager)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{project_port}}/api/projects/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{project_port}}",
              "path": [
                "api",
                "projects",
                "{{project_id}}"
              ]
            }
          }
        },
        {
          "name": "2.4 Update Project (Manager)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{project_port}}/api/projects/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{project_port}}",
              "path": [
                "api",
                "projects",
                "{{project_id}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Refonte Web V2\"}"
            }
          }
        },
        {
          "name": "2.5 Delete Project (Manager)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{project_port}}/api/projects/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{project_port}}",
              "path": [
                "api",
                "projects",
                "{{project_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Tasks",
      "item": [
        {
          "name": "3.1 Create Task (Manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('task_id', pm.response.json().task._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{task_port}}/api/tasks",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{task_port}}",
              "path": [
                "api",
                "tasks"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Frontend\",\"description\":\"React App\",\"projectId\":\"{{project_id}}\",\"assignedTo\":\"{{member_id}}\"}"
            }
          }
        },
        {
          "name": "3.2 Update Task Status (Member)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_member}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{task_port}}/api/tasks/{{task_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{task_port}}",
              "path": [
                "api",
                "tasks",
                "{{task_id}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"in_progress\"}"
            }
          }
        },
        {
          "name": "3.3 Get Tasks by Project (Member)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_member}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{task_port}}/api/tasks/project/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{task_port}}",
              "path": [
                "api",
                "tasks",
                "project",
                "{{project_id}}"
              ]
            }
          }
        },
        {
          "name": "3.4 Get Tasks by User (Member)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_member}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{task_port}}/api/tasks/user/{{member_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{task_port}}",
              "path": [
                "api",
                "tasks",
                "user",
                "{{member_id}}"
              ]
            }
          }
        },
        {
          "name": "3.5 Delete Task (Manager)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{task_port}}/api/tasks/{{task_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{task_port}}",
              "path": [
                "api",
                "tasks",
                "{{task_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. History",
      "item": [
        {
          "name": "4.1 Get All History (Manager/Member)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{history_port}}/api/history",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{history_port}}",
              "path": [
                "api",
                "history"
              ]
            }
          }
        },
        {
          "name": "4.2 Get History by Task",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{history_port}}/api/history/task/{{task_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{history_port}}",
              "path": [
                "api",
                "history",
                "task",
                "{{task_id}}"
              ]
            }
          }
        },
        {
          "name": "4.3 Get History by Project",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_manager}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{history_port}}/api/history/project/{{project_id}}",
              "host": [
                "{{base_url}}"
              ],
              "port": "{{history_port}}",
              "path": [
                "api",
                "history",
                "project",
                "{{project_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}