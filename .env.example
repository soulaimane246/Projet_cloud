# Configuration racine pour tous les services
# Copier ce fichier dans chaque dossier de service et renommer en .env

# === AUTH SERVICE (Port 3000) ===
# Fichier : auth-service/.env
AUTH_PORT=3000
AUTH_MONGO_URI=mongodb://mongo-auth:27017/auth

# === PROJECT SERVICE (Port 3001) ===
# Fichier : project-service/.env
PROJECT_PORT=3001
PROJECT_MONGO_URI=mongodb://mongo-projects:27017/projects

# === TASK SERVICE (Port 3002) ===
# Fichier : task-service/.env
TASK_PORT=3002
TASK_MONGO_URI=mongodb://mongo-tasks:27017/tasks

# === HISTORY SERVICE (Port 3003) ===
# Fichier : history-service/.env
HISTORY_PORT=3003
HISTORY_MONGO_URI=mongodb://mongo-history:27017/history

# === JWT Configuration (Identique pour tous les services) ===
JWT_SECRET=supersecretkey123
JWT_EXPIRES_IN=7d

# === RabbitMQ Configuration ===
RABBITMQ_URL=amqp://rabbitmq:5672

# === Inter-Service Communication ===
PROJECT_SERVICE_URL=http://project-service:3001

# === Environment ===
NODE_ENV=production
